```gitignore
# =====================================================
# Frontend (React / Vite)
# =====================================================

node_modules/
dist/
.vite/
vite.svg

# npm / pnpm / yarn
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Coverage / tests
coverage/
.nyc_output/

# Environment files
.env
.env.*
!.env.example

# Cache
.cache/
.parcel-cache/

# =====================================================
# OS files
# =====================================================

.DS_Store
Thumbs.db

# =====================================================
# IDE / Editor
# =====================================================

.vscode/
.idea/
*.swp
*.swo
*~

# =====================================================
# Python / Jupyter (si utilisé)
# =====================================================

__pycache__/
*.pyc
.ipynb_checkpoints/

# =====================================================
# Docker
# =====================================================

docker-compose.override.yml

# =====================================================
# Build / temp files
# =====================================================

tmp/
temp/
*.tmp

# Archives
*.zip
*.tar
*.tar.gz

# =====================================================
# Logs
# =====================================================

logs/
*.log

# =====================================================
# Generated docs
# =====================================================

*.pdf

# =====================================================
# Local Kubernetes / OpenShift overrides
# =====================================================

*.local.yaml
*.override.yaml

# =====================================================
# Keep important packaging artifacts
# =====================================================

!packaging/
!packaging/k8s/
!packaging/*.sh
!packaging/db/*.dump

# =====================================================
# Keep runtime config template
# =====================================================

!public/config.js
